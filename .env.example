# Copy this file to .env and fill in real values before starting the stack.
# All keys must be regenerated for each deployment — never reuse secrets.

# AES-256-GCM key used to encrypt landlord signatures at rest.
# Required. 32 raw bytes encoded as 64 hex chars.
# Generate with: openssl rand -hex 32
SIGNATURE_ENCRYPTION_KEY=

# JWT signing key for the session cookie.
# Required. Recommended length: 64 hex chars (32 bytes of entropy).
# Generate with: openssl rand -hex 32
SECRET_KEY=

# PostgreSQL password used by both the database container and the backend.
# Required. Use a long random value; do not reuse across deployments.
POSTGRES_PASSWORD=

# Set to "true" when serving the app over HTTPS so the session cookie carries
# the Secure flag. Leave empty (or "false") for plain-HTTP local dev.
COOKIE_SECURE=

# Host port for the frontend container. Default: 8080.
HOST_PORT=8080

# Timezone applied to every container. Default: UTC.
TZ=Europe/Paris
